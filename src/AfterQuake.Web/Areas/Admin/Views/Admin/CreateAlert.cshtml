@model AfterQuake.Application.DTOs.CreateAlertDto
@using AfterQuake.Domain.Enumerations
@{
    ViewData["Title"] = "Publicar Alerta";
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto px-4 py-6">
    <h1 class="text-xl font-bold text-gray-900 flex items-center gap-2 mb-6">
        <i class="bi bi-megaphone text-orange-500"></i>
        Publicar Alerta
    </h1>

    <form asp-action="CreateAlert" method="post" class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de alerta</label>
                <select asp-for="AlertType" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base">
                    @foreach (var type in Enum.GetValues<AlertType>())
                    {
                        <option value="@type">@type.ToString()</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Severidad</label>
                <select asp-for="Severity" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base">
                    @foreach (var sev in Enum.GetValues<AlertLevel>())
                    {
                        <option value="@sev">@sev.ToString()</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Título *</label>
                <input asp-for="Title" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base" placeholder="Título de la alerta" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Mensaje</label>
                <textarea asp-for="Message" rows="4" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base" placeholder="Descripción detallada..."></textarea>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Código de zona</label>
                    <input asp-for="ZoneCode" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base" placeholder="Ej: ZONA-001" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Expira</label>
                    <input asp-for="ExpiresAt" type="datetime-local" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base" />
                </div>
            </div>
            <label class="flex items-center gap-3">
                <input asp-for="RequiresAcknowledgement" type="checkbox" class="w-5 h-5 text-orange-500 rounded" />
                <span class="text-sm font-medium text-gray-700">Requiere acuse de recibo</span>
            </label>
        </div>

        <button type="submit" class="w-full bg-orange-600 text-white py-3 rounded-xl font-bold text-base tap-target hover:bg-orange-700 transition-colors mt-6">
            <i class="bi bi-send-fill"></i> Publicar alerta
        </button>
    </form>
</div>
