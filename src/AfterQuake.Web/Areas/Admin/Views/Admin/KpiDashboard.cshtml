@model DashboardDto
@{
    ViewData["Title"] = "Dashboard de KPIs";
}
<div class="max-w-7xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Indicadores Clave de Desempeño</h1>
    
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-red-600">@Model.ActiveEmergencies</div>
            <div class="text-xs text-gray-500">Emergencias activas</div>
        </div>
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-yellow-600">@Model.PendingHelpRequests</div>
            <div class="text-xs text-gray-500">Ayuda pendiente</div>
        </div>
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-green-600">@Model.AvailableVolunteers</div>
            <div class="text-xs text-gray-500">Voluntarios disponibles</div>
        </div>
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-blue-600">@Model.TotalDonationAmount.ToString("N0")</div>
            <div class="text-xs text-gray-500">Total donado</div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="font-bold text-gray-900 mb-4">Tiempos de Respuesta</h2>
            <div class="space-y-3">
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span class="text-gray-600">Tiempo promedio asignación</span>
                        <span class="font-medium" id="avg-assign-time">Calculando...</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-teal-500 h-2 rounded-full" style="width: 45%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span class="text-gray-600">Tiempo promedio resolución</span>
                        <span class="font-medium" id="avg-resolve-time">Calculando...</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-teal-500 h-2 rounded-full" style="width: 30%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
            <h2 class="font-bold text-gray-900 mb-4">Distribución por Zona</h2>
            <div id="zone-chart" class="h-48 flex items-center justify-center text-gray-400">
                <i class="bi bi-bar-chart text-4xl"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
        <h2 class="font-bold text-gray-900 mb-4">Exportar Reportes</h2>
        <div class="flex flex-wrap gap-3">
            <a href="/Admin/ExportEmergencies" class="bg-red-50 text-red-700 px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-red-100 no-underline">
                <i class="bi bi-filetype-csv"></i> Emergencias CSV
            </a>
            <a href="/Admin/ExportPersons" class="bg-yellow-50 text-yellow-700 px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-yellow-100 no-underline">
                <i class="bi bi-filetype-csv"></i> Personas CSV
            </a>
            <a href="/Admin/ExportDonations" class="bg-teal-50 text-teal-700 px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-teal-100 no-underline">
                <i class="bi bi-filetype-csv"></i> Donaciones CSV
            </a>
            <a href="/Admin/ExportDashboard" class="bg-purple-50 text-purple-700 px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-purple-100 no-underline">
                <i class="bi bi-filetype-html"></i> Dashboard HTML
            </a>
        </div>
    </div>
</div>
