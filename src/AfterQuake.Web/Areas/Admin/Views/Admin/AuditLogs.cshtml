@using AfterQuake.Domain.Entities
@model IReadOnlyList<AuditLog>
@{ ViewData["Title"] = "Registro de Auditoría"; Layout = "_Layout"; }
<div class="max-w-7xl mx-auto px-4 py-6">
    <div class="flex items-center gap-3 mb-6">
        <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center">
            <i class="bi bi-journal-text text-2xl"></i>
        </div>
        <div>
            <h1 class="text-xl font-bold text-gray-900">Registro de Auditoría</h1>
            <p class="text-sm text-gray-500">Todas las acciones administrativas del sistema</p>
        </div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Fecha</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Usuario</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Acción</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">Entidad</th>
                        <th class="px-4 py-3 text-left font-medium text-gray-500">IP</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var log in Model)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-3 text-gray-500 whitespace-nowrap">@log.Timestamp.ToString("g")</td>
                            <td class="px-4 py-3 text-gray-900">@(log.User?.Email ?? "Anónimo")</td>
                            <td class="px-4 py-3">
                                <span class="badge @(log.Action == "Create" ? "bg-green-100 text-green-700" : log.Action == "Delete" ? "bg-red-100 text-red-700" : "bg-blue-100 text-blue-700")">@log.Action</span>
                            </td>
                            <td class="px-4 py-3 text-gray-700">@log.EntityName</td>
                            <td class="px-4 py-3 text-gray-500 font-mono text-xs">@log.IpAddress</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-12 text-gray-500">No hay registros de auditoría.</div>
        }
    </div>
</div>
