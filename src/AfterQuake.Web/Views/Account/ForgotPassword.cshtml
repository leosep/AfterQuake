@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Recuperar Contraseña";
}
<div class="max-w-md mx-auto px-4 py-12">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Recuperar Contraseña</h1>
    <form method="post" class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-gray-700">Correo Electrónico</label>
            <input asp-for="Email" class="w-full px-4 py-2.5 rounded-xl border border-gray-200" />
            <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
        </div>
        <button type="submit" class="w-full bg-teal-600 text-white py-3 rounded-xl font-medium hover:bg-teal-700">
            Enviar enlace de recuperación
        </button>
    </form>
</div>
