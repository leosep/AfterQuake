@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
}
<div class="max-w-md mx-auto px-4 py-12">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Restablecer Contraseña</h1>
    <form method="post" class="space-y-4">
        <input type="hidden" asp-for="Token" />
        <input type="hidden" asp-for="Email" />
        <div>
            <label class="block text-sm font-medium text-gray-700">Nueva Contraseña</label>
            <input asp-for="Password" type="password" class="w-full px-4 py-2.5 rounded-xl border border-gray-200" />
            <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700">Confirmar Contraseña</label>
            <input asp-for="ConfirmPassword" type="password" class="w-full px-4 py-2.5 rounded-xl border border-gray-200" />
            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-sm"></span>
        </div>
        <button type="submit" class="w-full bg-teal-600 text-white py-3 rounded-xl font-medium hover:bg-teal-700">
            Restablecer contraseña
        </button>
    </form>
</div>
