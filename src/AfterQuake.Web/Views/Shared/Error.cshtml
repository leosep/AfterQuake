@model ErrorViewModel
@{ ViewData["Title"] = "Error"; }
<div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-md">
        <div class="w-24 h-24 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="bi bi-exclamation-triangle text-5xl text-red-600"></i>
        </div>
        <h1 class="text-4xl font-bold text-gray-900 mb-2">@Model.StatusCode</h1>
        <p class="text-xl text-gray-600 mb-2">@Model.Title</p>
        <p class="text-gray-500 mb-8">@Model.Message</p>
        <a href="/" class="inline-flex items-center gap-2 bg-teal-600 text-white px-6 py-3 rounded-xl font-medium no-underline hover:bg-teal-700">
            <i class="bi bi-house"></i> Volver al inicio
        </a>
    </div>
</div>
