@model DashboardDto
@{
    ViewData["Title"] = "AfterQuake - Respuesta ante Terremotos";
}

<div class="bg-red-600 text-white">
    <div class="max-w-7xl mx-auto px-4 py-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl sm:text-3xl font-bold flex items-center gap-3">
                    <i class="bi bi-shield-fill-check"></i>
                    AfterQuake
                </h1>
                <p class="text-red-100 text-sm mt-1">Sistema de Respuesta y Coordinación ante Terremotos</p>
            </div>
            @if (Model.LatestAlert != null)
            {
                <div class="bg-red-800/50 backdrop-blur rounded-xl px-4 py-3 border border-red-400/30 w-full sm:w-auto">
                    <div class="flex items-center gap-2 text-sm">
                        <i class="bi bi-megaphone-fill animate-pulse-emergency"></i>
                        <span class="font-semibold">@Model.LatestAlert.Title</span>
                    </div>
                    <p class="text-red-100 text-xs mt-1">@Model.LatestAlert.Message</p>
                </div>
            }
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 py-6">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-red-600">@Model.ActiveEmergencies</div>
            <div class="text-xs text-gray-500 mt-1">Emergencias activas</div>
        </div>
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-yellow-600">@Model.ActiveMissingPersons</div>
            <div class="text-xs text-gray-500 mt-1">Personas desaparecidas</div>
        </div>
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-blue-600">@Model.PendingHelpRequests</div>
            <div class="text-xs text-gray-500 mt-1">Solicitudes de ayuda</div>
        </div>
        <div class="card-emergency text-center">
            <div class="text-3xl font-bold text-green-600">@Model.AvailableShelterCapacity</div>
            <div class="text-xs text-gray-500 mt-1">Capacidad en albergues</div>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <a href="/Emergency/Report" class="block no-underline">
            <div class="bg-red-600 text-white rounded-2xl p-6 text-center hover:bg-red-700 active:bg-red-800 transition-all btn-emergency shadow-lg shadow-red-200">
                <i class="bi bi-exclamation-triangle-fill text-5xl block mb-3"></i>
                <h2 class="text-xl font-bold">¡EMERGENCIA!</h2>
                <p class="text-red-100 text-sm mt-1">Reportar una emergencia ahora</p>
            </div>
        </a>
        <div id="gps-error-banner" class="hidden bg-yellow-50 border border-yellow-200 rounded-xl p-3 text-yellow-800 text-sm">
            <i class="bi bi-exclamation-circle-fill"></i>
            No se pudo detectar tu ubicación automáticamente. Al reportar una emergencia, asegúrate de indicar una dirección manual.
        </div>

        <a href="/Person" class="block no-underline">
            <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-yellow-300 hover:shadow-lg transition-all text-center">
                <i class="bi bi-people-fill text-4xl text-yellow-500 block mb-3"></i>
                <h2 class="text-lg font-bold text-gray-800">Personas</h2>
                <p class="text-gray-500 text-sm">Buscar desaparecidos / Reportar encontrados</p>
            </div>
        </a>

        <a href="/HelpRequest/Create" class="block no-underline">
            <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-blue-300 hover:shadow-lg transition-all text-center">
                <i class="bi bi-hand-index-thumb-fill text-4xl text-blue-500 block mb-3"></i>
                <h2 class="text-lg font-bold text-gray-800">Pedir Ayuda</h2>
                <p class="text-gray-500 text-sm">Agua, comida, refugio, medicinas</p>
            </div>
        </a>

        <a href="/Shelter/Map" class="block no-underline">
            <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-green-300 hover:shadow-lg transition-all text-center">
                <i class="bi bi-map-fill text-4xl text-green-500 block mb-3"></i>
                <h2 class="text-lg font-bold text-gray-800">Mapa de Albergues</h2>
                <p class="text-gray-500 text-sm">Refugios, centros de salud, puntos de acopio</p>
            </div>
        </a>

        <a href="/Directory" class="block no-underline">
            <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-purple-300 hover:shadow-lg transition-all text-center">
                <i class="bi bi-telephone-fill text-4xl text-purple-500 block mb-3"></i>
                <h2 class="text-lg font-bold text-gray-800">Contactos de Emergencia</h2>
                <p class="text-gray-500 text-sm">Bomberos, Cruz Roja, hospitales</p>
            </div>
        </a>

        <a href="/Guide" class="block no-underline">
            <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-teal-300 hover:shadow-lg transition-all text-center">
                <i class="bi bi-book-fill text-4xl text-teal-500 block mb-3"></i>
                <h2 class="text-lg font-bold text-gray-800">Guías de Seguridad</h2>
                <p class="text-gray-500 text-sm">Qué hacer antes, durante y después</p>
            </div>
        </a>
    </div>

    @if (Model.UrgentRequests.Any())
    {
        <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-5 mb-8">
            <h3 class="font-bold text-yellow-800 flex items-center gap-2 mb-4">
                <i class="bi bi-exclamation-circle-fill"></i>
                Solicitudes Urgentes
            </h3>
            <div class="space-y-3">
                @foreach (var req in Model.UrgentRequests.Take(5))
                {
                    <div class="flex items-start gap-3 bg-white rounded-xl p-3">
                        <span class="badge status-critical"><i class="bi bi-flag-fill"></i></span>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-900">@req.RequestTypeName - @req.RequesterName</p>
                            <p class="text-xs text-gray-500 truncate">@req.Description</p>
                        </div>
                        <span class="text-xs text-gray-400 whitespace-nowrap">@req.RequestedAt.ToString("HH:mm")</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <h3 class="font-bold text-gray-800 flex items-center gap-2 mb-3">
            <i class="bi bi-telephone"></i>
            Líneas de Emergencia
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <a href="tel:911" class="flex items-center gap-2 bg-red-50 hover:bg-red-100 rounded-xl p-3 no-underline transition-colors">
                <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center">
                    <i class="bi bi-telephone-fill"></i>
                </div>
                <div>
                    <div class="text-sm font-bold text-gray-900">911</div>
                    <div class="text-xs text-gray-500">Emergencias</div>
                </div>
            </a>
            <a href="tel:911" class="flex items-center gap-2 bg-red-50 hover:bg-red-100 rounded-xl p-3 no-underline transition-colors">
                <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center">
                    <i class="bi bi-truck"></i>
                </div>
                <div>
                    <div class="text-sm font-bold text-gray-900">Bomberos</div>
                    <div class="text-xs text-gray-500">Incendios / Rescates</div>
                </div>
            </a>
            <a href="tel:911" class="flex items-center gap-2 bg-red-50 hover:bg-red-100 rounded-xl p-3 no-underline transition-colors">
                <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <div>
                    <div class="text-sm font-bold text-gray-900">Cruz Roja</div>
                    <div class="text-xs text-gray-500">Atención médica</div>
                </div>
            </a>
            <a href="tel:911" class="flex items-center gap-2 bg-red-50 hover:bg-red-100 rounded-xl p-3 no-underline transition-colors">
                <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div>
                    <div class="text-sm font-bold text-gray-900">Defensa Civil</div>
                    <div class="text-xs text-gray-500">Protección civil</div>
                </div>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    document.getElementById('sos-lat')?.setAttribute('value', pos.coords.latitude);
                    document.getElementById('sos-lng')?.setAttribute('value', pos.coords.longitude);
                },
                () => {
                    var banner = document.getElementById('gps-error-banner');
                    if (banner) banner.classList.remove('hidden');
                },
                { enableHighAccuracy: true, timeout: 10000 }
            );
        } else {
            var banner = document.getElementById('gps-error-banner');
            if (banner) banner.classList.remove('hidden');
        }
    </script>
}
