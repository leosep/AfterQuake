@model IReadOnlyList<ShelterDto>
@{
    ViewData["Title"] = "Albergues";
}

<div class="max-w-7xl mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center">
                <i class="bi bi-building text-2xl"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-gray-900">Albergues</h1>
                <p class="text-sm text-gray-500">Refugios temporales disponibles</p>
            </div>
        </div>
        <div class="flex gap-2">
            <a href="/Shelter/Map" class="tap-target bg-green-600 text-white px-4 py-2.5 rounded-xl font-medium no-underline hover:bg-green-700 transition-colors text-sm flex items-center gap-1">
                <i class="bi bi-map"></i> Ver mapa
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-16">
            <i class="bi bi-house-x text-6xl text-gray-300 block mb-4"></i>
            <h2 class="text-lg font-medium text-gray-500">No hay albergues registrados</h2>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var shelter in Model)
            {
                <div class="card-emergency">
                    <div class="flex items-start justify-between mb-3">
                        <h3 class="font-bold text-gray-900">@shelter.Name</h3>
                        <span class="badge
                            @(shelter.Status == ShelterStatus.Active ? "bg-green-100 text-green-700" :
                              shelter.Status == ShelterStatus.Full ? "bg-yellow-100 text-yellow-700" :
                              "bg-red-100 text-red-700")">
                            @shelter.StatusName
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(shelter.Description))
                    {
                        <p class="text-sm text-gray-500 mb-3">@shelter.Description</p>
                    }
                    <div class="bg-gray-50 rounded-xl p-3 mb-3">
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-xs text-gray-500">Ocupación</span>
                            <span class="text-sm font-bold">@shelter.CurrentOccupancy / @shelter.TotalCapacity</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2.5">
                            <div class="bg-green-500 h-2.5 rounded-full transition-all" style="width: @(shelter.TotalCapacity > 0 ? (shelter.CurrentOccupancy * 100 / shelter.TotalCapacity) : 0)%"></div>
                        </div>
                        <p class="text-xs text-green-600 font-medium mt-1">@shelter.AvailableCapacity lugares disponibles</p>
                    </div>
                    <div class="flex flex-wrap gap-1.5">
                        @if (shelter.HasElectricity) { <span class="badge bg-green-100 text-green-700"><i class="bi bi-lightning"></i> Luz</span> }
                        @if (shelter.HasWater) { <span class="badge bg-blue-100 text-blue-700"><i class="bi bi-droplet"></i> Agua</span> }
                        @if (shelter.HasMedicalPost) { <span class="badge bg-red-100 text-red-700"><i class="bi bi-heart-pulse"></i> Médico</span> }
                        @if (shelter.HasFoodSupply) { <span class="badge bg-yellow-100 text-yellow-700"><i class="bi bi-basket"></i> Comida</span> }
                    </div>
                    @if (!string.IsNullOrEmpty(shelter.Address))
                    {
                        <p class="text-xs text-gray-400 mt-3"><i class="bi bi-geo-alt"></i> @shelter.Address</p>
                    }
                    @if (!string.IsNullOrEmpty(shelter.ContactPhone))
                    {
                        <a href="tel:@shelter.ContactPhone" class="mt-2 inline-flex items-center gap-1 text-sm text-blue-600 no-underline">
                            <i class="bi bi-telephone"></i> @shelter.ContactPhone
                        </a>
                    }
                </div>
            }
        </div>
    }
</div>
