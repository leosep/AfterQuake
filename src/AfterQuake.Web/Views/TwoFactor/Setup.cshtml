@{
    ViewData["Title"] = "Configurar 2FA";
}
<div class="max-w-2xl mx-auto px-4 py-6">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 max-w-md mx-auto">
        <h1 class="text-xl font-bold text-gray-900 mb-4">Autenticación de Dos Factores</h1>
        <p class="text-sm text-gray-500 mb-4">Escanea el código QR con Google Authenticator o Microsoft Authenticator:</p>
        <div class="flex justify-center mb-4">
            <div id="qrcode"></div>
        </div>
        <p class="text-sm text-gray-500 mb-2">O ingresa manualmente esta clave:</p>
        <p class="text-center font-mono text-lg bg-gray-100 p-3 rounded-xl mb-4" id="shared-key">@ViewBag.SharedKey</p>
        <form method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Código de verificación</label>
                <input type="text" name="code" required maxlength="6" pattern="[0-9]*" inputmode="numeric"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-center text-2xl tracking-widest" />
            </div>
            <button type="submit" class="w-full bg-teal-600 text-white py-3 rounded-xl font-medium hover:bg-teal-700">
                Verificar y activar
            </button>
        </form>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
    new QRCode(document.getElementById('qrcode'), { text: '@ViewBag.AuthenticatorUri', width: 200, height: 200 });
</script>
