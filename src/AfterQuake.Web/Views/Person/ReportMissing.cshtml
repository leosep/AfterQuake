@model CreatePersonReportDto
@{
    ViewData["Title"] = "Reportar Persona Desaparecida";
}

<div class="max-w-2xl mx-auto px-4 py-6">
    <div class="flex items-center gap-3 mb-6">
        <div class="w-12 h-12 bg-red-100 text-red-600 rounded-xl flex items-center justify-center">
            <i class="bi bi-person-x-fill text-2xl"></i>
        </div>
        <div>
            <h1 class="text-xl font-bold text-gray-900">Reportar persona desaparecida</h1>
            <p class="text-sm text-gray-500">Completa los datos de la persona que buscas</p>
        </div>
    </div>

    @if (TempData["PotentialMatches"] is string json)
    {
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-6">
            <div class="flex items-start gap-3">
                <i class="bi bi-exclamation-triangle text-yellow-500 text-xl"></i>
                <div>
                    <h3 class="font-semibold text-yellow-800 text-sm">Posibles coincidencias encontradas</h3>
                    <p class="text-xs text-yellow-700 mt-1">Revisa si alguna de estas personas es quien buscas:</p>
                    <div class="mt-2 space-y-1">
                        @foreach (var match in System.Text.Json.JsonSerializer.Deserialize<List<PersonReportDto>>(json) ?? new())
                        {
                            <div class="text-xs text-yellow-800">@match.MissingPersonName - @match.ZoneCode</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <form asp-action="ReportMissing" method="post" class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

        <div class="space-y-4">
            <h2 class="font-semibold text-gray-700 text-sm flex items-center gap-2">
                <i class="bi bi-info-circle"></i> Datos de la persona desaparecida
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nombre completo *</label>
                    <input asp-for="MissingPersonName" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" placeholder="Nombre y apellidos" />
                    <span asp-validation-for="MissingPersonName" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Edad aproximada</label>
                    <input asp-for="Age" type="number" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Género</label>
                    <select asp-for="Gender" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500">
                        <option value="">Seleccionar</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Fecha/hora última vez visto</label>
                    <input asp-for="LastSeenAt" type="datetime-local" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descripción física</label>
                <textarea asp-for="Description" rows="2" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" placeholder="Contextura, estatura, color de pelo, ojos..."></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Señas particulares</label>
                <textarea asp-for="PhysicalCharacteristics" rows="2" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" placeholder="Tatuajes, cicatrices, lunares, vestimenta..."></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Foto de la persona</label>
                <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-yellow-400 cursor-pointer">
                    <i class="bi bi-camera text-3xl text-gray-300 block mb-2"></i>
                    <p class="text-sm text-gray-500">Toca para subir una foto</p>
                    <input asp-for="PhotoBase64" type="file" accept="image/*" class="hidden" />
                </div>
            </div>

            <h2 class="font-semibold text-gray-700 text-sm flex items-center gap-2 mt-6">
                <i class="bi bi-geo-alt"></i> Última ubicación conocida
            </h2>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Dirección / zona</label>
                <input asp-for="LastKnownAddress" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" placeholder="Calle, número, comuna..." />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Código de zona</label>
                <input asp-for="ZoneCode" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" placeholder="Ej: ZONA-001" />
            </div>

            <h2 class="font-semibold text-gray-700 text-sm flex items-center gap-2 mt-6">
                <i class="bi bi-telephone"></i> Tu información de contacto
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nombre del contacto</label>
                    <input asp-for="ContactName" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" placeholder="Tu nombre" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono *</label>
                    <input asp-for="ContactPhone" type="tel" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-yellow-500 focus:border-yellow-500" placeholder="+56 9 1234 5678" />
                    <span asp-validation-for="ContactPhone" class="text-red-500 text-xs"></span>
                </div>
            </div>
        </div>

        <div class="mt-6 space-y-3">
            <button type="submit" class="w-full bg-red-600 text-white py-4 rounded-xl font-bold text-lg tap-target hover:bg-red-700 active:bg-red-800 transition-colors">
                <i class="bi bi-send-fill"></i> REPORTAR COMO DESAPARECIDO
            </button>
            <a href="/Person" class="block w-full text-center text-gray-500 py-3 rounded-xl font-medium hover:bg-gray-50 transition-colors no-underline">
                Cancelar
            </a>
        </div>
    </form>
</div>
