@model CreateHelpRequestDto
@{
    ViewData["Title"] = "Solicitar Ayuda";
}

<div class="max-w-2xl mx-auto px-4 py-6">
    <div class="flex items-center gap-3 mb-6">
        <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center">
            <i class="bi bi-hand-index-thumb-fill text-2xl"></i>
        </div>
        <div>
            <h1 class="text-xl font-bold text-gray-900">Solicitar ayuda</h1>
            <p class="text-sm text-gray-500">Selecciona qué tipo de ayuda necesitas</p>
        </div>
    </div>

    <form asp-action="Create" method="post" class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">¿Qué necesitas? *</label>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                    @foreach (var type in Enum.GetValues<HelpRequestType>())
                    {
                        <label class="flex items-center gap-2 p-3 border border-gray-200 rounded-xl cursor-pointer hover:border-blue-300 hover:bg-blue-50 transition-all">
                            <input type="radio" name="RequestType" value="@type" class="text-blue-600" />
                            <span class="text-sm">@type</span>
                        </label>
                    }
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
                <textarea asp-for="Description" rows="3" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Describe qué necesitas..."></textarea>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Personas afectadas</label>
                    <input asp-for="PeopleCount" type="number" min="1" value="1" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Código de zona</label>
                    <input asp-for="ZoneCode" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Ej: ZONA-001" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
                <input asp-for="Address" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Calle, número, sector..." />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tu nombre</label>
                    <input asp-for="RequesterName" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Nombre completo" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono *</label>
                    <input asp-for="RequesterPhone" type="tel" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="+1 809 555 1234" />
                </div>
            </div>

            <label class="flex items-center gap-3 p-3 bg-red-50 rounded-xl cursor-pointer">
                <input asp-for="IsUrgent" type="checkbox" class="w-5 h-5 text-red-600 rounded" />
                <span class="text-sm font-medium text-red-700">Es una emergencia urgente</span>
            </label>

            <input asp-for="Latitude" type="hidden" id="help-lat" />
            <input asp-for="Longitude" type="hidden" id="help-lng" />
        </div>

        <div class="mt-6 space-y-3">
            <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-xl font-bold text-lg tap-target hover:bg-blue-700 active:bg-blue-800 transition-colors">
                <i class="bi bi-send-fill"></i> ENVIAR SOLICITUD
            </button>
            <a href="/" class="block w-full text-center text-gray-500 py-3 rounded-xl font-medium hover:bg-gray-50 transition-colors no-underline">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    document.getElementById('help-lat').value = pos.coords.latitude;
                    document.getElementById('help-lng').value = pos.coords.longitude;
                },
                () => {},
                { enableHighAccuracy: true, timeout: 10000 }
            );
        }
    </script>
}
