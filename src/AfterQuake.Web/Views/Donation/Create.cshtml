@model CreateDonationDto
@{
    ViewData["Title"] = "Hacer una Donación";
}

<div class="max-w-2xl mx-auto px-4 py-6">
    <div class="flex items-center gap-3 mb-6">
        <div class="w-12 h-12 bg-teal-100 text-teal-600 rounded-xl flex items-center justify-center">
            <i class="bi bi-gift-fill text-2xl"></i>
        </div>
        <div>
            <h1 class="text-xl font-bold text-gray-900">Hacer una donación</h1>
            <p class="text-sm text-gray-500">Tu ayuda llega a quienes más lo necesitan</p>
        </div>
    </div>

    <form asp-action="Create" method="post" class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de donación *</label>
                <div class="grid grid-cols-2 gap-2">
                    @foreach (var type in Enum.GetValues<DonationType>())
                    {
                        <label class="flex items-center gap-2 p-3 border border-gray-200 rounded-xl cursor-pointer hover:border-teal-300 hover:bg-teal-50 transition-all">
                            <input type="radio" name="DonationType" value="@((int)type)" class="text-teal-600" />
                            <span class="text-sm">@(type == DonationType.Monetary ? "Dinero" : "Artículos")</span>
                        </label>
                    }
                </div>
            </div>

            <div id="monetary-fields" class="hidden">
                <label class="block text-sm font-medium text-gray-700 mb-1">Monto en DOP</label>
                <input asp-for="MonetaryAmount" type="number" step="0.01" min="1" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-teal-500 focus:border-teal-500" placeholder="1,000" />
            </div>

            <div id="item-fields" class="hidden">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Artículo</label>
                        <input asp-for="ItemName" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-teal-500 focus:border-teal-500" placeholder="Agua, comida, ropa..." />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Cantidad</label>
                        <input asp-for="ItemQuantity" type="number" min="1" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-teal-500 focus:border-teal-500" placeholder="10" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Unidad</label>
                    <input asp-for="ItemUnit" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-teal-500 focus:border-teal-500" placeholder="litros, kilos, unidades..." />
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
                <textarea asp-for="Description" rows="3" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-teal-500 focus:border-teal-500" placeholder="Describe tu donación..."></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tu nombre</label>
                <input asp-for="DonorName" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-teal-500 focus:border-teal-500" placeholder="Nombre completo" />
            </div>

            <label class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl cursor-pointer">
                <input asp-for="IsAnonymous" type="checkbox" class="w-5 h-5 text-teal-600 rounded" />
                <span class="text-sm font-medium text-gray-700">Donar de forma anónima</span>
            </label>

            @if (ViewBag.DonationPoints is IReadOnlyList<DonationPoint> points && points.Any())
            {
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Punto de acopio</label>
                    <select asp-for="DonationPointId" class="w-full rounded-xl border-gray-300 border px-4 py-3 text-base focus:ring-2 focus:ring-teal-500 focus:border-teal-500">
                        <option value="">Seleccionar punto de acopio</option>
                        @foreach (var point in points)
                        {
                            <option value="@point.Id">@point.Name</option>
                        }
                    </select>
                </div>
            }
        </div>

        <div class="mt-6 space-y-3">
            <button type="submit" class="w-full bg-teal-600 text-white py-4 rounded-xl font-bold text-lg tap-target hover:bg-teal-700 active:bg-teal-800 transition-colors">
                <i class="bi bi-send-fill"></i> ENVIAR DONACIÓN
            </button>
            <a href="/Donation" class="block w-full text-center text-gray-500 py-3 rounded-xl font-medium hover:bg-gray-50 transition-colors no-underline">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('input[name="DonationType"]').forEach(function(radio) {
            radio.addEventListener('change', function() {
                document.getElementById('monetary-fields').classList.toggle('hidden', this.value !== '0');
                document.getElementById('item-fields').classList.toggle('hidden', this.value !== '1');
            });
        });
    </script>
}
