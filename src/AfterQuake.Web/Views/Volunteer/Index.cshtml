@model IReadOnlyList<Volunteer>
@{
    ViewData["Title"] = "Voluntarios";
}

<div class="max-w-7xl mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center">
                <i class="bi bi-heart-fill text-2xl"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-gray-900">Voluntarios</h1>
                <p class="text-sm text-gray-500">Personas dispuestas a ayudar</p>
            </div>
        </div>
        <a href="/Volunteer/Register" class="tap-target bg-indigo-600 text-white px-4 py-2.5 rounded-xl font-medium no-underline hover:bg-indigo-700 text-sm flex items-center gap-1">
            <i class="bi bi-person-plus"></i> Registrarme
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-16">
            <i class="bi bi-heart text-6xl text-gray-300 block mb-4"></i>
            <h2 class="text-lg font-medium text-gray-500">No hay voluntarios disponibles</h2>
            <p class="text-sm text-gray-400 mt-1">Regístrate para ayudar</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var volunteer in Model)
            {
                <div class="card-emergency">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center">
                            <i class="bi bi-person text-xl"></i>
                        </div>
                        <div>
                            <p class="font-medium text-gray-900">@volunteer.User?.FullName ?? "Voluntario"</p>
                            <span class="badge @(volunteer.IsAvailable ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600")">
                                @(volunteer.IsAvailable ? "Disponible" : "No disponible")
                            </span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(volunteer.Skills))
                    {
                        <div class="flex flex-wrap gap-1">
                            @foreach (var skill in volunteer.Skills.Split(','))
                            {
                                <span class="badge bg-indigo-100 text-indigo-700">@skill.Trim()</span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(volunteer.ZoneCode))
                    {
                        <p class="text-xs text-gray-400 mt-2"><i class="bi bi-geo-alt"></i> @volunteer.ZoneCode</p>
                    }
                </div>
            }
        </div>
    }
</div>
